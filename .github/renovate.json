{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["github>valentjn/renovate"],
    "packageRules": [
        {
            // disable updating Python as it is tied to the Pyodide version used by PyScript
            "enabled": false,
            "groupName": "Python",
            "matchPackageNames": ["python"]
        }
    ]
}
